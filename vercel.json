{
  "version": 2,
  "builds": [
    {
      "src": "**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/analyze_url",
      "destination": "https://instagram-sentiment-platform.onrender.com/analyze_url"
    },
    {
      "source": "/analyze_file",
      "destination": "https://instagram-sentiment-platform.onrender.com/analyze_file"
    },
    {
      "source": "/me",
      "destination": "https://instagram-sentiment-platform.onrender.com/me"
    },
    {
      "source": "/login",
      "destination": "https://instagram-sentiment-platform.onrender.com/login"
    },
    {
      "source": "/register",
      "destination": "https://instagram-sentiment-platform.onrender.com/register"
    },
    {
      "source": "/health",
      "destination": "https://instagram-sentiment-platform.onrender.com/health"
    },
    {
      "source": "/results",
      "destination": "https://instagram-sentiment-platform.onrender.com/results"
    },
    {
      "source": "/history",
      "destination": "https://instagram-sentiment-platform.onrender.com/history"
    },
    {
      "source": "/logout",
      "destination": "https://instagram-sentiment-platform.onrender.com/logout"
    },
    {
      "source": "/reset-password-request",
      "destination": "https://instagram-sentiment-platform.onrender.com/reset-password-request"
    },
    {
      "source": "/reset-password",
      "destination": "https://instagram-sentiment-platform.onrender.com/reset-password"
    },
    {
      "source": "/update_profile",
      "destination": "https://instagram-sentiment-platform.onrender.com/update_profile"
    },
    {
      "source": "/compare",
      "destination": "https://instagram-sentiment-platform.onrender.com/compare"
    },
    {
      "source": "/init_db",
      "destination": "https://instagram-sentiment-platform.onrender.com/init_db"
    },
    {
      "source": "/google_client_id",
      "destination": "https://instagram-sentiment-platform.onrender.com/google_client_id"
    },
    {
      "source": "/download_report",
      "destination": "https://instagram-sentiment-platform.onrender.com/download_report"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}
